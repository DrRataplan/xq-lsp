{
	"name": "xquery-lsp-vscode",
	"displayName": "XQuery Language Server",
	"description": "XQuery language support via xq-lsp",
	"version": "0.5.0",
	"publisher": "elliat",
	"license": "MIT",
	"engines": {
		"vscode": "^1.86.0",
		"cursor": "^1.86.0"
	},
	"repository": "https://github.com/DrRataplan/xq-lsp.git",
	"categories": [
		"Programming Languages",
		"Formatters"
	],
	"activationEvents": [],
	"contributes": {
		"languages": [
			{
				"id": "xquery",
				"aliases": [
					"XQuery",
					"xquery"
				],
				"extensions": [
					".xq",
					".xql",
					".xqm",
					".xqy"
				],
				"configuration": "./language-configuration.json"
			}
		]
	},
	"main": "./dist/extension.js",
	"scripts": {
		"build": "node build.mjs",
		"package": "node build.mjs && vsce package --no-dependencies",
		"test:e2e": "node e2e/runTests.mjs",
		"publish:vsce": "vsce publish",
		"publish:ovsx": "ovsx publish"
	},
	"dependencies": {
		"prettier": "^3.8.3",
		"prettier-plugin-xquery": "^1.6.0",
		"vscode-languageclient": "^9.0.1",
		"xq-lsp": "file:../.."
	},
	"devDependencies": {
		"@vscode/test-electron": "^2.4.0",
		"@vscode/vsce": "^3.0.0",
		"esbuild": "^0.28.0",
		"ovsx": "^0.9.0"
	}
}
