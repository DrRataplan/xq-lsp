{
  "name": "xq-lsp",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "author": "Martin Middel",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "xq-lsp": "./src/server.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node ./src/server.ts --stdio",
    "test": "node --test src/test.ts",
    "demo": "node --experimental-strip-types demo/server.ts",
    "build-demo": "esbuild demo/browser-entry.ts --bundle --format=iife --global-name=xqlsp --outfile=demo/xq-lsp.bundle.js --alias:vscode-languageserver/node.js=./demo/shims/vscode-lsp.js --loader:.xq=text --minify"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "xq-parser": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
