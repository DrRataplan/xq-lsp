{
	"name": "xq-lsp",
	"version": "1.4.0",
	"description": "XQuery Language Server Protocol implementation",
	"license": "MIT",
	"author": "Martin Middel",
	"type": "module",
	"main": "dist/server.js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DrRataplan/xq-lsp.git"
	},
	"bin": {
		"xq-lsp": "src/server.ts"
	},
	"scripts": {
		"build": "tsc",
		"start": "node ./src/server.ts --stdio",
		"test": "node --test",
		"test:coverage": "mkdir -p coverage && node --experimental-test-coverage --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-coverage-exclude='src/**/*.test.ts'",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"fontoxpath": "^3.34.0",
		"slimdom": "^4.3.5",
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.12",
		"xq-parser": "^0.4.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-xquery": "^1.6.1",
		"typescript": "^6.0.3"
	}
}
